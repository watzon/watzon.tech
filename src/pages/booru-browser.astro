                  <li class="bb-starter-chip" style={`--c:${s.hue}`}>
                    <span class="bb-mark bb-mark--sm" style={`--c:${s.hue}`}><span>{s.mark}</span></span>
                    {s.name}
                  </li>
                ))}
              </ul>
              <a class="bb-starter-dl" href={listUrl} download="servers.booruconfig.json">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
                Download the list
              </a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer class="bb-footer">
      <a href="/" class="bb-back" data-astro-reload>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Back to watzon.tech
      </a>
      <nav class="bb-footer-nav">
        <a href="/booru-browser/privacy">Privacy</a>
        <a href="/booru-browser/terms">Terms</a>
      </nav>
      <span class="bb-footer-meta">© {new Date().getFullYear()} Chris Watson</span>
    </footer>

    <!-- Scroll reveal (self-contained; respects reduced motion) -->
    <script is:inline>
      (function () {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          document.querySelectorAll("[data-reveal]").forEach(function (el) {
            el.classList.add("in");
          });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add("in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
        );
        document.querySelectorAll("[data-reveal]").forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>

    <style is:global>
      /* ============================================================
         BOORU BROWSER — dark-only theme takeover
         Self-contained; palette + display face match the real app
         (deep navy #010C2E, pink/violet brand gradient, Baloo 2).
         ============================================================ */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bb-bg: #010c2e;
        --bb-bg-2: #061238;
        --bb-text: #eef0fb;
        --bb-muted: #9aa0c8;
        --bb-faint: #6a6f9c;
        --bb-border: rgba(255, 255, 255, 0.09);
        --bb-surface: rgba(255, 255, 255, 0.04);
        --bb-surface-2: rgba(255, 255, 255, 0.06);
        --bb-pink: #ff5fb0;
        --bb-violet: #9b6bff;
        --bb-cyan: #3fc9ff;
        --bb-gold: #ffb23e;
        --bb-grad: linear-gradient(135deg, #ff5fb0, #9b6bff);
        --bb-display: "Baloo 2", "SF Pro Rounded", system-ui, sans-serif;
        --bb-body: "Figtree", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        --bb-ease: cubic-bezier(0.16, 1, 0.3, 1);
        /* Radius lock: badges/buttons pill, cards 20px, tiles 12px, marks 14px */
        --r-card: 20px;
        --r-tile: 12px;
      }

      html.bb-root { background: var(--bb-bg); scroll-behavior: smooth; }

      body.bb {
        font-family: var(--bb-body);
        background:
          radial-gradient(125% 75% at 50% -12%, #122163 0%, rgba(18, 33, 99, 0) 55%),
          var(--bb-bg);
        color: var(--bb-text);
        line-height: 1.6;
        font-size: 1.0625rem;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
        position: relative;
        min-height: 100dvh;
      }

      body.bb a { color: inherit; text-decoration: none; }
      body.bb ul { list-style: none; }
      body.bb ::selection { background: rgba(255, 95, 176, 0.35); }
      body.bb :focus-visible { outline: 2px solid var(--bb-pink); outline-offset: 3px; border-radius: 6px; }

      /* ---------- Backdrop ---------- */
      .bb-backdrop { position: fixed; inset: 0; z-index: 0; overflow: hidden; pointer-events: none; }
      .bb-glow {
        position: absolute; top: -10%; right: -6%; width: 60vw; height: 60vw;
        max-width: 760px; max-height: 760px; border-radius: 50%;
        background: radial-gradient(circle, rgba(255, 95, 176, 0.28), rgba(155, 107, 255, 0.14) 42%, transparent 70%);
        filter: blur(60px);
      }
      .bb-grain {
        position: absolute; inset: 0;
        background-image: radial-gradient(rgba(255, 255, 255, 0.5) 0.5px, transparent 0.5px);
        background-size: 4px 4px; opacity: 0.02;
      }

      /* ---------- Layout shell ---------- */
      main, .bb-topbar, .bb-footer { position: relative; z-index: 1; }
      .bb-section, .bb-hero, .bb-topbar, .bb-footer, .bb-trust, .bb-getcta-inner {
        width: 100%; max-width: 1200px; margin: 0 auto; padding-left: 1.5rem; padding-right: 1.5rem;
      }

      /* ---------- Top bar ---------- */
      .bb-topbar {
        display: flex; align-items: center; justify-content: space-between;
        padding-top: 1.4rem; padding-bottom: 1.4rem; font-size: 0.9rem; font-weight: 500;
      }
      .bb-back { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--bb-muted); transition: color 0.2s; }
      .bb-back:hover { color: var(--bb-text); }
      .bb-back svg { transition: transform 0.25s var(--bb-ease); }
      .bb-back:hover svg { transform: translateX(-3px); }
      .bb-topbar-link { display: inline-flex; align-items: center; gap: 0.45rem; color: var(--bb-muted); transition: color 0.2s; }
      .bb-topbar-link:hover { color: var(--bb-cyan); }

      /* ---------- Hero ---------- */
      .bb-hero {
        display: grid; grid-template-columns: 1.05fr 0.95fr; align-items: center; gap: 2.5rem;
        padding-top: clamp(1.5rem, 4vw, 3rem); padding-bottom: clamp(3rem, 8vw, 5.5rem);
        min-height: min(86dvh, 760px);
      }
      .bb-lockup { display: inline-flex; align-items: center; gap: 0.8rem; margin-bottom: 1.6rem; }
      .bb-lockup-icon { width: 52px; height: 52px; border-radius: 14px; box-shadow: 0 8px 24px -8px rgba(0, 0, 0, 0.7); }
      .bb-lockup-text { display: flex; flex-direction: column; line-height: 1.15; }
      .bb-lockup-name { font-family: var(--bb-display); font-weight: 700; font-size: 1.05rem; letter-spacing: -0.01em; }
      .bb-lockup-sub { font-size: 0.8rem; color: var(--bb-faint); }

      .bb-title {
        font-family: var(--bb-display); font-weight: 800; line-height: 1.0; letter-spacing: -0.03em;
        font-size: clamp(2.6rem, 6.4vw, 4.7rem); margin-bottom: 1.4rem; color: var(--bb-text);
      }
      .bb-lede { font-size: clamp(1.08rem, 1.5vw, 1.28rem); color: var(--bb-muted); max-width: 34ch; margin-bottom: 2rem; }

      .bb-cta { display: flex; flex-wrap: wrap; gap: 0.85rem; align-items: center; }
      .bb-cta--center { justify-content: center; }

      /* Store badges */
      .bb-badge {
        display: inline-flex; align-items: center; gap: 0.6rem;
        padding: 0.7rem 1.15rem; border-radius: 999px; line-height: 1;
        border: 1px solid var(--bb-border); background: var(--bb-surface-2); color: var(--bb-text);
        transition: transform 0.25s var(--bb-ease), border-color 0.25s, background 0.25s, box-shadow 0.25s;
      }
      .bb-badge svg { flex-shrink: 0; }
      .bb-badge-stack { display: flex; flex-direction: column; align-items: flex-start; gap: 1px; }
      .bb-badge-stack small { font-size: 0.62rem; font-weight: 500; letter-spacing: 0.04em; color: var(--bb-muted); text-transform: uppercase; }
      .bb-badge-stack strong { font-family: var(--bb-display); font-size: 1.05rem; font-weight: 700; letter-spacing: -0.01em; }
      .bb-badge--apple {
        background: var(--bb-grad); border-color: transparent; color: #fff;
        box-shadow: 0 12px 34px -12px rgba(255, 95, 176, 0.7);
      }
      .bb-badge--apple .bb-badge-stack small { color: rgba(255, 255, 255, 0.82); }
      .bb-badge:hover { transform: translateY(-2px); }
      .bb-badge--apple:hover { box-shadow: 0 18px 44px -12px rgba(255, 95, 176, 0.85); }
      .bb-badge--ghost:hover { border-color: rgba(255, 255, 255, 0.25); background: rgba(255, 255, 255, 0.08); }
      .bb-badge:active { transform: translateY(0) scale(0.98); }

      /* ---------- Hero stage (phone + floaters) ---------- */
      .bb-hero-stage { position: relative; display: grid; place-items: center; min-height: 540px; }
      .bb-floater {
        position: absolute; width: clamp(110px, 13vw, 168px); aspect-ratio: 3 / 4;
        border-radius: var(--r-tile); background-size: cover; background-position: center;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 18px 40px -16px rgba(0, 0, 0, 0.7); z-index: 0; opacity: 0.92;
      }
      .bb-floater--1 { top: 4%; left: 0; transform: rotate(-7deg); animation: bb-float-a 8s ease-in-out infinite; }
      .bb-floater--2 { bottom: 6%; right: -2%; transform: rotate(8deg); animation: bb-float-b 9s ease-in-out infinite; }
      @keyframes bb-float-a { 50% { transform: rotate(-7deg) translateY(-16px); } }
      @keyframes bb-float-b { 50% { transform: rotate(8deg) translateY(-20px); } }

      /* ---------- Phone mockup ---------- */
      .bb-phone {
        position: relative; z-index: 1; width: 100%; max-width: 300px; aspect-ratio: 9 / 19.5;
        border-radius: 38px; padding: 9px;
        background: linear-gradient(165deg, #1a2356, #060c26);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 40px 80px -30px rgba(0, 0, 0, 0.85), inset 0 0 0 1.5px rgba(255, 255, 255, 0.05);
      }
      .bb-phone--hero { animation: bb-phone-float 7s ease-in-out infinite; }
      @keyframes bb-phone-float { 50% { transform: translateY(-12px); } }
      /* In-phone chrome scales with the phone's own width (container units),
         so the header and dock stay correctly proportioned on the large hero
         phone and the smaller showcase phones alike. */
      .bb-screen {
        position: relative; width: 100%; height: 100%; border-radius: 30px; overflow: hidden;
        background: #0a1130; container-type: inline-size;
      }

      /* App header (overlays the grid, translucent like the real app).
         Sizes use container units so the chrome stays in proportion on the
         large hero phone and the smaller showcase phones alike. */
      .bb-apphead {
        position: absolute; top: 0; left: 0; right: 0; z-index: 3;
        padding: 2.8cqw 3.4cqw 4cqw;
        background: linear-gradient(180deg, rgba(7, 12, 36, 0.96) 45%, rgba(7, 12, 36, 0));
        -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
      }
      .bb-statusbar {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 2cqw; margin-bottom: 6cqw;
        font-weight: 700; color: var(--bb-text);
      }
      .bb-sb-time { font-size: 11px; font-size: 3.4cqw; letter-spacing: 0.02em; }
      /* Dynamic Island — the top safe-area pill */
      .bb-island { width: 26cqw; height: 6.4cqw; border-radius: 999px; background: #05060f; flex-shrink: 0; }
      .bb-statusbar-r { display: inline-flex; gap: 1.7cqw; align-items: center; color: var(--bb-text); }
      .bb-statusbar-r .bb-sb { height: 3cqw; width: auto; fill: currentColor; }
      .bb-apphead-row { display: flex; align-items: center; justify-content: space-between; }
      .bb-apphead-title { font-family: var(--bb-display); font-weight: 800; font-size: 19px; font-size: 7.2cqw; letter-spacing: -0.01em; color: var(--bb-text); }
      .bb-apphead-tools { display: inline-flex; gap: 3.2cqw; color: var(--bb-pink); }
      .bb-apphead-tools svg { width: 5.8cqw; height: 5.8cqw; }

      /* Gallery wall — edge-to-edge masonry, sharp corners (matches the app) */
      .bb-galwall {
        position: absolute; inset: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 3px; overflow: hidden;
      }
      .bb-galcol { display: flex; flex-direction: column; gap: 3px; will-change: transform; }
      .bb-galcol--up { animation: bb-scroll 26s linear infinite; }
      .bb-galcol--up2 { animation: bb-scroll 32s linear infinite; }
      @keyframes bb-scroll { from { transform: translateY(0); } to { transform: translateY(-50%); } }
      .bb-tile {
        display: block; width: 100%; background-size: cover; background-position: center;
        background-color: color-mix(in srgb, var(--c) 26%, #0a1130);
      }
      /* Compact even grid */
      .bb-galgrid { position: absolute; inset: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 3px; align-content: start; overflow: hidden; }
      .bb-galgrid span { aspect-ratio: 4 / 5; background-size: cover; background-position: center; background-color: #141a37; }
      /* Single column */
      .bb-galsingle { position: absolute; inset: 0; display: flex; flex-direction: column; gap: 3px; overflow: hidden; }
      .bb-galsingle span { width: 100%; aspect-ratio: 5 / 6; flex-shrink: 0; background-size: cover; background-position: center; background-color: #141a37; }

      /* Floating dock — capsule [Browse · favorites · settings] + detached search */
      .bb-dock {
        position: absolute; left: 0; right: 0; bottom: 3.4cqw; z-index: 4;
        display: flex; align-items: center; justify-content: space-between; gap: 1.8cqw; padding: 0 3.2cqw;
      }
      .bb-dock-bar {
        flex: 1; min-width: 0;
        display: flex; align-items: center; justify-content: space-between; gap: 1.4cqw; padding: 1.5cqw 4cqw 1.5cqw 1.5cqw; border-radius: 999px;
        background: rgba(12, 18, 44, 0.55); border: 1px solid rgba(255, 255, 255, 0.16);
        -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px);
        box-shadow: 0 2.5cqw 6cqw -2.5cqw rgba(0, 0, 0, 0.7);
      }
      .bb-dock-browse {
        flex: 0 1 auto; display: inline-flex; align-items: center; justify-content: center; gap: 1.6cqw; padding: 2cqw 7cqw; border-radius: 999px;
        background: linear-gradient(90deg, #ff5fb0, #9b6bff); color: #fff; font-family: var(--bb-display); font-weight: 700; font-size: 13px; font-size: 4.4cqw;
        box-shadow: 0 1.6cqw 3.6cqw -1.6cqw rgba(255, 95, 176, 0.6);
      }
      .bb-dock-browse svg { width: 4.6cqw; height: 4.6cqw; flex-shrink: 0; }
      .bb-dock-ic { color: var(--bb-faint); display: inline-grid; place-items: center; }
      .bb-dock-ic svg { width: 5.4cqw; height: 5.4cqw; }
      .bb-dock-search {
        width: 12cqw; height: 12cqw; border-radius: 50%; display: inline-grid; place-items: center; flex-shrink: 0; color: #fff;
        background: linear-gradient(135deg, rgba(255, 95, 176, 0.72), rgba(155, 107, 255, 0.9));
        border: 1px solid rgba(255, 255, 255, 0.2);
        -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);
        box-shadow: 0 2cqw 5cqw -2cqw rgba(155, 107, 255, 0.8);
      }
      .bb-dock-search svg { width: 5.6cqw; height: 5.6cqw; }

      /* Board switcher overlay (long-press the search button in the real app) */
      .bb-switch-scrim { position: absolute; inset: 0; z-index: 2; background: rgba(2, 6, 22, 0.55); }
      /* Pops up from the search button: anchored bottom-right, stacks upward. */
      .bb-switcher {
        position: absolute; right: 2.4cqw; top: 7cqw; bottom: 22.5cqw; z-index: 4;
        display: flex; flex-direction: column; align-items: flex-end; justify-content: flex-end; gap: 1.8cqw;
      }
      .bb-swpill {
        padding: 2.2cqw 4cqw; border-radius: 999px; white-space: nowrap;
        font-family: var(--bb-display); font-weight: 700; font-size: 12px; font-size: 3.7cqw; color: #fff;
        background: rgba(22, 28, 58, 0.85); border: 1px solid rgba(255, 255, 255, 0.1);
        -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
      }
      .bb-swpill--current { background: var(--bb-grad); border-color: transparent; box-shadow: 0 1.6cqw 4cqw -1.6cqw rgba(255, 95, 176, 0.7); }
      .bb-swpill--active { background: rgba(255, 178, 62, 0.2); border-color: rgba(255, 178, 62, 0.6); color: #ffd591; }

      /* ---------- Trust strip ---------- */
      .bb-trust { padding-top: clamp(1rem, 3vw, 2rem); }
      .bb-trust-grid {
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px;
        background: var(--bb-border); border: 1px solid var(--bb-border); border-radius: var(--r-card); overflow: hidden;
      }
      .bb-trust-item {
        display: flex; flex-direction: column; gap: 0.3rem; padding: 1.4rem 1.5rem;
        background: var(--bb-bg);
      }
      .bb-trust-ico {
        display: inline-grid; place-items: center; width: 34px; height: 34px; border-radius: 10px;
        color: var(--c); background: color-mix(in srgb, var(--c) 15%, transparent);
        margin-bottom: 0.6rem;
      }
      .bb-trust-item strong { font-family: var(--bb-display); font-size: 1.1rem; font-weight: 700; letter-spacing: -0.01em; color: var(--bb-text); line-height: 1.2; }
      .bb-trust-item small { font-size: 0.85rem; color: var(--bb-muted); line-height: 1.45; }

      /* ---------- Sections ---------- */
      .bb-section { padding-top: clamp(3.5rem, 8vw, 7rem); padding-bottom: clamp(0.5rem, 2vw, 1rem); }
      .bb-section--tight { padding-top: clamp(2.5rem, 5vw, 4rem); }
      .bb-section-head { margin-bottom: clamp(2rem, 4vw, 3rem); max-width: 42ch; }
      .bb-kicker {
        display: inline-block; text-transform: uppercase; letter-spacing: 0.16em; font-size: 0.74rem;
        font-weight: 600; color: var(--bb-pink); margin-bottom: 0.85rem;
      }
      .bb-h2 {
        font-family: var(--bb-display); font-weight: 700; letter-spacing: -0.02em; line-height: 1.08;
        font-size: clamp(1.8rem, 3.6vw, 2.7rem);
      }
      .bb-updated { color: var(--bb-faint); font-size: 0.85rem; margin-top: 0.65rem; }

      /* ---------- Feature bento ---------- */
      .bb-bento {
        display: grid; grid-template-columns: repeat(6, 1fr); gap: 1rem;
        grid-auto-rows: minmax(150px, auto);
      }
      .bb-cell {
        position: relative; padding: 1.6rem; border-radius: var(--r-card);
        background: var(--bb-surface); border: 1px solid var(--bb-border); overflow: hidden;
        transition: transform 0.35s var(--bb-ease), border-color 0.35s, background 0.35s;
      }
      .bb-cell:hover { transform: translateY(-4px); border-color: color-mix(in srgb, var(--c, var(--bb-pink)) 45%, transparent); background: var(--bb-surface-2); }
      .bb-cell--sources { grid-column: span 3; grid-row: span 2; display: flex; flex-direction: column; justify-content: space-between; gap: 1.5rem; }
      .bb-cell--private { grid-column: span 3; }
      .bb-cell--speed { grid-column: span 3; display: flex; gap: 1.25rem; align-items: stretch; }
      .bb-cell--speed .bb-cell-body { flex: 1; }
      .bb-cell--sfw { grid-column: span 2; }
      .bb-cell--search { grid-column: span 2; }
      .bb-cell--favs { grid-column: span 2; }

      .bb-cell-ico {
        display: inline-grid; place-items: center; width: 42px; height: 42px; border-radius: 12px;
        color: var(--c, var(--bb-pink)); background: color-mix(in srgb, var(--c, var(--bb-pink)) 16%, transparent);
        margin-bottom: 1rem;
      }
      .bb-cell-title { font-family: var(--bb-display); font-size: 1.2rem; font-weight: 700; letter-spacing: -0.01em; margin-bottom: 0.45rem; }
      .bb-cell--sources .bb-cell-title { font-size: 1.45rem; }
      .bb-cell-text { color: var(--bb-muted); font-size: 0.92rem; line-height: 1.55; }

      .bb-sourcemarks { display: flex; flex-wrap: wrap; gap: 0.6rem; }
      .bb-mark {
        width: 46px; height: 46px; border-radius: 14px; display: grid; place-items: center;
        font-family: var(--bb-display); font-weight: 700; font-size: 0.95rem;
        color: var(--c); background: color-mix(in srgb, var(--c) 14%, transparent);
        border: 1px solid color-mix(in srgb, var(--c) 38%, transparent);
        transition: transform 0.25s var(--bb-ease);
      }
      .bb-cell--sources:hover .bb-mark { transform: translateY(-2px); }

      .bb-minigrid { display: grid; grid-template-columns: repeat(2, 56px); grid-auto-rows: 56px; gap: 5px; align-content: center; flex-shrink: 0; }
      .bb-minigrid span { border-radius: 9px; background-size: cover; background-position: center; background-color: rgba(255, 255, 255, 0.05); }
      .bb-minigrid span:nth-child(n+5) { display: none; }

      /* ---------- Screens showcase ---------- */
      .bb-showcase { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; align-items: end; }
      .bb-show { display: flex; flex-direction: column; align-items: center; gap: 1rem; }
      .bb-show .bb-phone { max-width: 230px; transition: transform 0.4s var(--bb-ease); }
      .bb-show--a, .bb-show--c { transform: translateY(-1.5rem); }
      .bb-show:hover .bb-phone { transform: translateY(-8px); }
      .bb-show figcaption { font-size: 0.85rem; color: var(--bb-muted); font-weight: 500; }

      /* ---------- Tech strip ---------- */
      .bb-tech-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.16em; color: var(--bb-faint); margin-bottom: 1.1rem; }
      .bb-stack { display: flex; flex-wrap: wrap; gap: 0.6rem; }
      .bb-chip {
        font-size: 0.82rem; font-weight: 500; color: var(--bb-text);
        padding: 0.45rem 0.9rem; border-radius: 999px;
        background: var(--bb-surface); border: 1px solid var(--bb-border);
        transition: border-color 0.25s, color 0.25s, background 0.25s;
      }
      .bb-chip:hover { border-color: rgba(255, 255, 255, 0.25); color: #fff; background: var(--bb-surface-2); }

      /* ---------- Starter list (secondary block inside the final CTA) ---------- */
      .bb-mark--sm { width: 30px; height: 30px; border-radius: 50%; font-size: 0.72rem; }
      .bb-starter {
        display: flex; align-items: center; justify-content: center; gap: 1.5rem;
        max-width: 540px; margin: clamp(2rem, 4vw, 2.75rem) auto 0; padding-top: clamp(2rem, 4vw, 2.75rem);
        border-top: 1px solid var(--bb-border); text-align: left;
      }
      .bb-qr {
        flex-shrink: 0; background: #fff; border-radius: 14px; padding: 6px; line-height: 0;
        box-shadow: 0 14px 36px -18px rgba(0, 0, 0, 0.7);
      }
      .bb-qr img { display: block; width: 132px; height: auto; }
      .bb-starter-side { min-width: 0; }
      .bb-starter-lede { color: var(--bb-muted); font-size: 0.92rem; line-height: 1.5; margin-bottom: 0.85rem; }
      .bb-starter-marks { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
      .bb-starter-chip {
        display: inline-flex; align-items: center; gap: 0.45rem; padding: 0.25rem 0.7rem 0.25rem 0.3rem;
        border-radius: 999px; font-size: 0.82rem; font-weight: 500; color: var(--bb-text);
        background: var(--bb-surface-2); border: 1px solid var(--bb-border);
      }
      .bb-starter-dl {
        display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.88rem; font-weight: 500;
        color: var(--bb-cyan); transition: color 0.2s;
      }
      .bb-starter-dl:hover { color: #7de0ff; }

      /* ---------- Final CTA ---------- */
      .bb-getcta { padding-top: clamp(3.5rem, 8vw, 6.5rem); }
      .bb-getcta-inner {
        position: relative; text-align: center; padding: clamp(2.5rem, 5vw, 4rem) 1.5rem;
        border-radius: 28px; border: 1px solid var(--bb-border); overflow: hidden;
        background:
          radial-gradient(90% 130% at 50% -20%, rgba(255, 95, 176, 0.16), transparent 60%),
          var(--bb-surface);
      }
      .bb-getcta-icon { width: 72px; height: 72px; border-radius: 18px; margin: 0 auto 1.2rem; box-shadow: 0 12px 30px -10px rgba(0, 0, 0, 0.7); }
      .bb-getcta-title { margin-bottom: 0.6rem; }
      .bb-getcta-sub { color: var(--bb-muted); margin-bottom: 1.8rem; }

      /* ---------- Footer ---------- */
      .bb-footer {
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
        padding-top: 2.5rem; padding-bottom: 2.5rem; margin-top: clamp(3rem, 6vw, 5rem);
        border-top: 1px solid var(--bb-border); color: var(--bb-faint); font-size: 0.85rem;
      }
      .bb-footer-nav { display: inline-flex; gap: 1.4rem; }
      .bb-footer-nav a { color: var(--bb-muted); transition: color 0.2s; }
      .bb-footer-nav a:hover { color: var(--bb-text); }

      /* ---------- Entrance + reveal animations ---------- */
      .bb-fade { opacity: 0; transform: translateY(1.4rem); animation: bb-enter 0.8s var(--bb-ease) forwards; animation-delay: var(--d, 0s); }
      @keyframes bb-enter { to { opacity: 1; transform: none; } }
      [data-reveal] { opacity: 0; transform: translateY(1.6rem); transition: opacity 0.7s var(--bb-ease), transform 0.7s var(--bb-ease); }
      [data-reveal].in { opacity: 1; transform: none; }
      .bb-show--a, .bb-show--c { transform: translateY(-1.5rem); }

      /* ---------- Responsive ---------- */
      @media (max-width: 980px) {
        .bb-bento { grid-template-columns: repeat(2, 1fr); }
        .bb-cell--sources { grid-column: span 2; grid-row: auto; }
        .bb-cell--private, .bb-cell--speed { grid-column: span 2; }
        .bb-cell--sfw, .bb-cell--search, .bb-cell--favs { grid-column: span 2; }
        .bb-showcase { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
        .bb-show--a, .bb-show--c { transform: none; }
      }
      @media (max-width: 760px) {
        .bb-hero { grid-template-columns: 1fr; text-align: center; gap: 2rem; min-height: 0; }
        .bb-hero-copy { order: 2; }
        .bb-hero-stage { order: 1; min-height: 460px; }
        .bb-lockup, .bb-cta, .bb-lede { margin-left: auto; margin-right: auto; }
        .bb-cta { justify-content: center; }
        .bb-trust-grid { grid-template-columns: repeat(2, 1fr); }
        .bb-starter { flex-direction: column; text-align: center; }
        .bb-starter-marks { justify-content: center; }
      }
      @media (max-width: 520px) {
        body.bb { font-size: 1rem; }
        .bb-bento { grid-template-columns: 1fr; }
        .bb-cell--sources, .bb-cell--private, .bb-cell--speed,
        .bb-cell--sfw, .bb-cell--search, .bb-cell--favs { grid-column: span 1; }
        .bb-cell--speed { flex-direction: column; }
        .bb-minigrid { grid-template-columns: repeat(4, 1fr); }
        .bb-minigrid span:nth-child(n+5) { display: block; }
        .bb-showcase { grid-template-columns: 1fr; max-width: 280px; margin-inline: auto; }
        .bb-trust-grid { grid-template-columns: 1fr; }
      }

      /* ---------- Reduced motion ---------- */
      @media (prefers-reduced-motion: reduce) {
        .bb-floater, .bb-phone--hero, .bb-galcol--up, .bb-galcol--up2, .bb-caret { animation: none !important; }
        .bb-floater--1 { transform: rotate(-7deg); }
        .bb-floater--2 { transform: rotate(8deg); }
        .bb-fade { opacity: 1 !important; transform: none !important; animation: none !important; }
        [data-reveal] { opacity: 1 !important; transform: none !important; transition: none !important; }
        .bb-show--a, .bb-show--c { transform: translateY(-1.5rem); }
        html.bb-root { scroll-behavior: auto; }
      }
    </style>
  </body>
</html>

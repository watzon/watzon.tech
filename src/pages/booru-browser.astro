---
import SEO from "../components/SEO.astro";

const githubUrl = "https://github.com/watzon/booru-browser";
// Shipping an iOS TestFlight beta first; Android comes later. Replace with the
// real public TestFlight invite link once the build is live.
const testflightUrl = "https://testflight.apple.com/join/REPLACE_ME";

// Gallery imagery: real rating:safe posts pulled from Safebooru (the board the
// mockups depict) and self-hosted under /images/booru/gallery. Each tile keeps a
// brand-tinted fallback colour so it reads as intentional before the image loads.
// NOTE: these are third-party fan works shown without per-artist credit; swap for
// owned/licensed assets (or add attribution) before any public launch.
const hues = ["var(--bb-pink)", "var(--bb-cyan)", "var(--bb-violet)", "var(--bb-gold)"];
const G = (n) => `/images/booru/gallery/${String(((n - 1) % 24) + 1).padStart(2, "0")}.jpg`;
const masonry = (shapes, start) =>
  shapes.map((ar, i) => ({ ar, img: G(start + i), hue: hues[(start + i) % 4] }));
// Two-column masonry sets (varied aspect ratios = real booru grid rhythm).
const heroA = masonry(["3 / 4", "2 / 3", "3 / 5", "4 / 5", "2 / 3"], 1);
const heroB = masonry(["2 / 3", "3 / 4", "4 / 5", "3 / 4", "3 / 5"], 6);
const showA = masonry(["2 / 3", "3 / 4", "4 / 5", "2 / 3", "3 / 4"], 11);
const showB = masonry(["3 / 4", "2 / 3", "3 / 5", "4 / 5", "2 / 3"], 16);
const gridImgs = [21, 22, 23, 24, 3, 8, 13, 18].map(G);
const singleImgs = [4, 12, 20].map(G);
const miniImgs = [1, 2, 5, 7, 9, 11, 14, 17].map(G);
const float1 = G(19);
const float2 = G(24);

// Supported source families, with monogram marks in brand hues.
const sources = [
  { name: "Danbooru", mark: "D", hue: "var(--bb-pink)" },
  { name: "Gelbooru", mark: "G", hue: "var(--bb-cyan)" },
  { name: "e621", mark: "e6", hue: "var(--bb-gold)" },
  { name: "Konachan", mark: "K", hue: "var(--bb-violet)" },
  { name: "Kemono", mark: "Ke", hue: "var(--bb-pink)" },
  { name: "Custom", mark: "+", hue: "var(--bb-cyan)" },
];

const stack = [
  "Expo SDK 54",
  "React Native",
  "TypeScript",
  "React Query",
  "Zustand",
  "expo-secure-store",
  "FlashList",
  "Reanimated",
];

// Mockup data — the in-app screens are recreated from the real app's actual
// layout (a real mini-version of the UI, not a fake screenshot). The app shows
// the active board's name as the screen title and toggles between masonry,
// compact-grid, and single-column layouts.
// The quick board switcher (long-press the search button). These are boards the
// user has added — the app ships with no bundled server list. Current = gradient.
const switcher = [
  { name: "Konachan" },
  { name: "Konachan (SFW)", state: "active" },
  { name: "e926 (SFW)" },
  { name: "Hypnohub" },
  { name: "Gelbooru" },
  { name: "Danbooru" },
  { name: "e621" },
  { name: "Safebooru", state: "current" },
];

// Curated, strictly-SFW starter list (the app ships with no servers). The JSON
// and QR live in /public/booru-browser; the QR encodes a boorubrowser://import
// deep link pointing at the hosted list.
const listUrl = "/booru-browser/servers.booruconfig.json";
const starterServers = [
  { name: "Safebooru", host: "safebooru.org", mark: "S", hue: "var(--bb-pink)" },
  { name: "e926", host: "e926.net", mark: "e9", hue: "var(--bb-gold)" },
  { name: "Konachan", host: "konachan.net", mark: "K", hue: "var(--bb-violet)" },
];
---

<!DOCTYPE html>
<html lang="en" data-theme="dark" class="bb-root">
  <head>
    <SEO
      title="Booru Browser — A private, gallery-first booru client"
      description="A fast, privacy-first mobile image browser for the booru ecosystem. Pluggable sources, a structural SFW age-gate, and credentials sealed in the device keychain. Built with Expo."
      image="/images/projects/booru-browser.png"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Baloo 2 is the app's actual display face; Figtree carries body copy. -->
    <link
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Figtree:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <!-- This page is a deliberate dark-only theme takeover; force it before paint. -->
    <script is:inline>
      document.documentElement.setAttribute("data-theme", "dark");
    </script>
    <!-- Without JS the scroll-reveal never fires; keep all content (incl. the
         privacy policy) fully visible as a fallback. -->
    <noscript>
      <style>
        [data-reveal] { opacity: 1 !important; transform: none !important; }
        .bb-fade { opacity: 1 !important; transform: none !important; animation: none !important; }
      </style>
    </noscript>
  </head>
  <body class="bb">
    <!-- Restrained brand backdrop: one top wash + a single soft glow + grain. -->
    <div class="bb-backdrop" aria-hidden="true">
      <span class="bb-glow"></span>
      <div class="bb-grain"></div>
    </div>

    <!-- Top bar -->
    <header class="bb-topbar">
      <a href="/" class="bb-back" data-astro-reload>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        watzon.tech
      </a>
      <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="bb-topbar-link">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 1C5.92 1 1 5.92 1 12c0 4.87 3.15 8.99 7.52 10.45.55.1.75-.24.75-.53v-1.85c-3.06.67-3.71-1.48-3.71-1.48-.5-1.27-1.22-1.61-1.22-1.61-1-.68.08-.67.08-.67 1.1.08 1.69 1.14 1.69 1.14.98 1.69 2.58 1.2 3.21.92.1-.71.39-1.2.7-1.48-2.44-.28-5.01-1.22-5.01-5.44 0-1.2.43-2.18 1.13-2.95-.11-.28-.49-1.4.11-2.92 0 0 .92-.3 3.02 1.13a10.4 10.4 0 0 1 5.5 0c2.1-1.43 3.02-1.13 3.02-1.13.6 1.52.22 2.64.11 2.92.7.77 1.13 1.75 1.13 2.95 0 4.23-2.58 5.16-5.03 5.43.4.34.75 1.01.75 2.04v3.03c0 .29.2.64.76.53A11.01 11.01 0 0 0 23 12c0-6.08-4.92-11-11-11Z"/></svg>
        GitHub
      </a>
    </header>

    <main>
      <!-- HERO -->
      <section class="bb-hero">
        <div class="bb-hero-copy">
          <div class="bb-lockup bb-fade" style="--d:0s">
            <img src="/images/booru/icon-square.png" alt="Booru Browser app icon" class="bb-lockup-icon" width="56" height="56" />
            <div class="bb-lockup-text">
              <span class="bb-lockup-name">Booru Browser</span>
              <span class="bb-lockup-sub">Free, open source</span>
            </div>
          </div>
          <h1 class="bb-title bb-fade" style="--d:.08s">Every booru.<br />One beautiful app.</h1>
          <p class="bb-lede bb-fade" style="--d:.16s">
            A fast, private, gallery-first browser for the booru ecosystem.
            Every source, one interface, zero tracking.
          </p>
          <div class="bb-cta bb-fade" style="--d:.24s">
            <a class="bb-badge bb-badge--apple" href={testflightUrl} target="_blank" rel="noopener noreferrer" aria-label="Join the TestFlight beta for iPhone">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M16.5 1.6c0 1.2-.5 2.4-1.3 3.3-.9 1-2.3 1.7-3.5 1.6-.1-1.2.5-2.4 1.3-3.2.9-1 2.4-1.7 3.5-1.7ZM20.3 17c-.6 1.4-.9 2-1.7 3.2-1 1.7-2.5 3.8-4.3 3.8-1.6 0-2-1-4.2-1-2.1 0-2.6 1-4.1 1-1.8 0-3.2-1.9-4.3-3.6C-.4 17 .5 11 3.7 9.4c1.3-.7 2.6-.6 3.8-.6 1.3 0 2.1.7 3.4.7 1.2 0 2-.7 3.5-.7 1.1 0 2.3.3 3.2 1-2.8 1.6-2.4 5.7.7 7.2Z"/></svg>
              <span class="bb-badge-stack"><small>iPhone beta on</small><strong>TestFlight</strong></span>
            </a>
            <a class="bb-badge bb-badge--ghost" href={githubUrl} target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 1C5.92 1 1 5.92 1 12c0 4.87 3.15 8.99 7.52 10.45.55.1.75-.24.75-.53v-1.85c-3.06.67-3.71-1.48-3.71-1.48-.5-1.27-1.22-1.61-1.22-1.61-1-.68.08-.67.08-.67 1.1.08 1.69 1.14 1.69 1.14.98 1.69 2.58 1.2 3.21.92.1-.71.39-1.2.7-1.48-2.44-.28-5.01-1.22-5.01-5.44 0-1.2.43-2.18 1.13-2.95-.11-.28-.49-1.4.11-2.92 0 0 .92-.3 3.02 1.13a10.4 10.4 0 0 1 5.5 0c2.1-1.43 3.02-1.13 3.02-1.13.6 1.52.22 2.64.11 2.92.7.77 1.13 1.75 1.13 2.95 0 4.23-2.58 5.16-5.03 5.43.4.34.75 1.01.75 2.04v3.03c0 .29.2.64.76.53A11.01 11.01 0 0 0 23 12c0-6.08-4.92-11-11-11Z"/></svg>
              <span class="bb-badge-stack"><strong>View on GitHub</strong></span>
            </a>
          </div>
        </div>

        <div class="bb-hero-stage bb-fade" style="--d:.2s">
          <span class="bb-floater bb-floater--1" aria-hidden="true" style={`background-image:url(${float1})`}></span>
          <span class="bb-floater bb-floater--2" aria-hidden="true" style={`background-image:url(${float2})`}></span>

          <div class="bb-phone bb-phone--hero">
            <div class="bb-screen">
              <!-- Browse / masonry screen, with a live auto-scrolling wall -->
              <div class="bb-galwall">
                <div class="bb-galcol bb-galcol--up">
                  {[...heroA, ...heroA].map((t) => (
                    <span class="bb-tile" style={`aspect-ratio:${t.ar}; --c:${t.hue}; background-image:url(${t.img})`}></span>
                  ))}
                </div>
                <div class="bb-galcol bb-galcol--up2">
                  {[...heroB, ...heroB].map((t) => (
                    <span class="bb-tile" style={`aspect-ratio:${t.ar}; --c:${t.hue}; background-image:url(${t.img})`}></span>
                  ))}
                </div>
              </div>
              <header class="bb-apphead">
                <div class="bb-statusbar"><span class="bb-sb-time">1:50</span><span class="bb-island" aria-hidden="true"></span><span class="bb-statusbar-r" aria-hidden="true"><svg class="bb-sb" viewBox="0 0 18 12"><rect x="0" y="8" width="3" height="4" rx="0.6"/><rect x="5" y="5.5" width="3" height="6.5" rx="0.6"/><rect x="10" y="3" width="3" height="9" rx="0.6"/><rect x="15" y="0" width="3" height="12" rx="0.6"/></svg><svg class="bb-sb" viewBox="0 0 16 12"><path d="M8 2C5 2 2.3 3.1.4 4.9l1.4 1.4C3.4 4.8 5.6 4 8 4s4.6.8 6.2 2.3l1.4-1.4C13.7 3.1 11 2 8 2Zm0 4c-1.7 0-3.3.6-4.5 1.7l1.5 1.5C5.7 8.5 6.8 8 8 8s2.3.5 3 1.2l1.5-1.5C11.3 6.6 9.7 6 8 6Zm0 3.8c-.7 0-1.3.3-1.8.7L8 12.3l1.8-1.8c-.5-.4-1.1-.7-1.8-.7Z"/></svg><svg class="bb-sb bb-sb-bat" viewBox="0 0 26 12"><rect x="0.5" y="1" width="21" height="10" rx="2.6" fill="none" stroke="currentColor" stroke-opacity="0.5"/><rect x="2" y="2.5" width="17" height="7" rx="1.4"/><rect x="23" y="4.2" width="2" height="3.6" rx="1"/></svg></span></div>
                <div class="bb-apphead-row">
                  <span class="bb-apphead-title">Safebooru</span>
                  <span class="bb-apphead-tools">
                    <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M6 12h12M9 18h6"/></svg>
                    <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="6" rx="1"/><rect x="14" y="11" width="7" height="10" rx="1"/></svg>
                  </span>
                </div>
              </header>
              <nav class="bb-dock">
                <div class="bb-dock-bar">
                  <span class="bb-dock-browse"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>Browse</span>
                  <span class="bb-dock-ic"><svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.5l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 18.5 6.1 20.5l1.2-6.5L2.5 9.4l6.6-.9z"/></svg></span>
                  <span class="bb-dock-ic"><svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-2.82 1.17V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 7.6 19.4l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 3 12.6H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 7.6l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6 1.65 1.65 0 0 0 10 3.09V3a2 2 0 0 1 4 0v.09A1.65 1.65 0 0 0 15 4.6l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z"/></svg></span>
                </div>
                <span class="bb-dock-search"><svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4-4"/></svg></span>
              </nav>
            </div>
          </div>
        </div>
      </section>

      <!-- TRUST STRIP -->
      <section class="bb-trust" aria-label="What sets it apart">
        <div class="bb-trust-grid" data-reveal>
          <span class="bb-trust-item" style="--c:var(--bb-pink)">
            <span class="bb-trust-ico"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9.9 4.24A9.1 9.1 0 0 1 12 4c7 0 10 8 10 8a18.5 18.5 0 0 1-2.16 3.19M6.6 6.6A18.6 18.6 0 0 0 2 12s3 8 10 8a9.3 9.3 0 0 0 5.4-1.6"/><path d="M2 2l20 20"/></svg></span>
            <strong>No tracking</strong>
            <small>Zero analytics, ads, or telemetry</small>
          </span>
          <span class="bb-trust-item" style="--c:var(--bb-cyan)">
            <span class="bb-trust-ico"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="7" rx="2"/><rect x="3" y="14" width="18" height="7" rx="2"/><path d="M7 6.5h.01M7 17.5h.01"/></svg></span>
            <strong>No servers</strong>
            <small>Nothing I operate sees your data</small>
          </span>
          <span class="bb-trust-item" style="--c:var(--bb-violet)">
            <span class="bb-trust-ico"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
            <strong>Keychain-sealed</strong>
            <small>Credentials never in plain storage</small>
          </span>
          <span class="bb-trust-item" style="--c:var(--bb-gold)">
            <span class="bb-trust-ico"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg></span>
            <strong>SFW by default</strong>
            <small>Mature content gated behind 17+</small>
          </span>
        </div>
      </section>

      <!-- FEATURES (bento) -->
      <section class="bb-section" id="features">
        <div class="bb-section-head" data-reveal>
          <span class="bb-kicker">What it does</span>
          <h2 class="bb-h2">Considered down to the last invariant.</h2>
        </div>

        <div class="bb-bento">
          <article class="bb-cell bb-cell--sources" data-reveal>
            <div class="bb-cell-body">
              <h3 class="bb-cell-title">Pluggable sources</h3>
              <p class="bb-cell-text">
                Danbooru, Gelbooru, e621, Moebooru, Kemono, and any custom site sit behind one
                adapter. Add a server, scan a QR code, or import a shareable config.
              </p>
            </div>
            <ul class="bb-sourcemarks" aria-label="Supported sources">
              {sources.map((s) => (
                <li class="bb-mark" style={`--c:${s.hue}`} title={s.name}><span>{s.mark}</span></li>
              ))}
            </ul>
          </article>

          <article class="bb-cell bb-cell--private" data-reveal style="--c:var(--bb-violet)">
            <span class="bb-cell-ico"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg></span>
            <h3 class="bb-cell-title">Private by design</h3>
            <p class="bb-cell-text">No analytics. No tracking. No bundled server list, and no servers I run. API keys are sealed in the device keychain, never in plain storage.</p>
          </article>

          <article class="bb-cell bb-cell--speed" data-reveal style="--c:var(--bb-gold)">
            <div class="bb-cell-body">
              <span class="bb-cell-ico"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8Z"/></svg></span>
              <h3 class="bb-cell-title">Built for speed</h3>
              <p class="bb-cell-text">Virtualized grids and aggressive image caching keep scrolling fluid across thousands of results. Browser-grade networking handles stubborn hosts.</p>
            </div>
            <div class="bb-minigrid" aria-hidden="true">
              {miniImgs.map((img) => (
                <span style={`background-image:url(${img})`}></span>
              ))}
            </div>
          </article>

          <article class="bb-cell bb-cell--sfw" data-reveal style="--c:var(--bb-cyan)">
            <span class="bb-cell-ico"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
            <h3 class="bb-cell-title">SFW by default</h3>
            <p class="bb-cell-text">A structural age gate every search passes through, so UI code physically can't bypass it. Mature content stays behind an explicit 18+ opt-in.</p>
          </article>

          <article class="bb-cell bb-cell--search" data-reveal style="--c:var(--bb-pink)">
            <span class="bb-cell-ico"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></span>
            <h3 class="bb-cell-title">Tag search, done right</h3>
            <p class="bb-cell-text">Per-source tag autocomplete, search history, and rating filters. Find exactly what you want without fighting query syntax.</p>
          </article>

          <article class="bb-cell bb-cell--favs" data-reveal style="--c:var(--bb-pink)">
            <span class="bb-cell-ico"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
            <h3 class="bb-cell-title">Favorites and downloads</h3>
            <p class="bb-cell-text">Save posts locally and export full-resolution media to your photo library or the share sheet. Your collection lives on your device.</p>
          </article>
        </div>
      </section>

      <!-- SCREENS SHOWCASE -->
      <section class="bb-section" id="screens">
        <div class="bb-section-head" data-reveal>
          <span class="bb-kicker">A look inside</span>
          <h2 class="bb-h2">Built to disappear behind the art.</h2>
        </div>

        <div class="bb-showcase" data-reveal>
          <!-- Masonry -->
          <figure class="bb-show bb-show--a">
            <div class="bb-phone">
              <div class="bb-screen">
                <div class="bb-galwall bb-galwall--static">
                  <div class="bb-galcol">{showA.map((t) => (<span class="bb-tile" style={`aspect-ratio:${t.ar}; --c:${t.hue}; background-image:url(${t.img})`}></span>))}</div>

---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'projects'>['data'];

const { name, description, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={`${name} - ${SITE_TITLE}`} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				@apply max-w-full m-0;
			}
			.hero-image {
				@apply w-full;
			}
			.hero-image img {
				@apply block mx-auto rounded-lg shadow-lg;
			}
			.prose {
				max-width: calc(100% - 2em);
				width: 720px;
				@apply mx-auto p-4 text-gray-700 dark:text-gray-300;
			}
			.title {
				@apply mb-4 py-4 text-center leading-8;
			}
			.title h1 {
				@apply m-0 mb-4;
			}
			.date {
				@apply mb-4 text-base text-gray-500;
			}
			.last-updated-on {
				@apply italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<h1>{name}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

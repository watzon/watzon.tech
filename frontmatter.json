{
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "default",
      "pageBundle": false,
      "previewPath": "'blog'",
      "filePrefix": null,
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string",
          "single": true
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string"
        },
        {
          "title": "Tags",
          "name": "tags",
          "type": "tags",
          "single": true
        },
        {
          "title": "Publishing date",
          "name": "date",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true
        },
        {
          "title": "Featured",
          "name": "featured",
          "type": "boolean"
        },
        {
          "title": "Draft",
          "name": "draft",
          "type": "boolean"
        },
        {
          "title": "OG image",
          "name": "ogImage",
          "type": "image"
        },
        {
          "title": "author",
          "name": "author",
          "type": "string"
        }
      ]
    }
  ],
  "frontMatter.content.supportedFileTypes": [
    "md",
    "markdown",
    "mdx"
  ]
}